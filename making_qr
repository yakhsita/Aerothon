      <visual name="visual">

        <geometry>
          <box>
            <size>6 0.01 6</size>
          </box>
        </geometry>

        <material>
          <diffuse>1 1 1 1</diffuse>
          <ambient>1 1 1 1</ambient>

          <pbr>
            <metal>
              <albedo_map>
