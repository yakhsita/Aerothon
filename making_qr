material QRCode1
{
  technique
  {
    pass
    {
      texture_unit
      {
        texture qr.png
      }
    }
  }
}

# Change the the model name & path location in the .sdf file (nano ~/qr3/model.sdf)(
?xml version="1.0" ?>
<sdf version="1.7">
